{
  "schemaVersion": 1,
  "applicationId": "easysubway",
  "releaseGate": "operations-release-evidence",
  "releaseBlockerPolicy": true,
  "evidenceRoot": ".codex/evidence/operations-release/<rc-or-run>",
  "deploymentWorkflow": {
    "requiredEvidence": [
      "cd-workflow-run-url",
      "backend-release-artifact-sha",
      "deployment-target-sha",
      "readiness-check-result",
      "rollback-drill-result"
    ],
    "blockedWhenKo": "CD run이 preflight만 수행했거나 deploy target, backend artifact, readiness, rollback 결과 중 하나라도 없으면 production release evidence로 인정하지 않는다."
  },
  "migrationPolicy": {
    "strategy": "expand-contract-or-backup-before-migration",
    "blockedIfMissingBackupBeforeMigration": true,
    "requiredEvidence": [
      "migration-diff-summary",
      "postgres-backup-before-migration",
      "restore-rehearsal-after-backup",
      "rollback-or-forward-fix-decision"
    ],
    "policyKo": "schema migration 변경이 있으면 expand/contract 호환성을 설명하거나 배포 전 PostgreSQL dump와 restore rehearsal 결과를 RC evidence에 남긴다."
  },
  "restoreRehearsal": {
    "requiredChecks": [
      "postgresql-restore-rehearsal",
      "facility-report-photo-restore-check",
      "datapack-source-inventory-validation",
      "datapack-release-manifest-restore"
    ],
    "blockedWhenKo": "database dump, object manifest, data source archive, datapack manifest history 중 하나라도 복구 검증이 없으면 release blocker로 처리한다."
  },
  "backendControlPlane": {
    "issue": 1017,
    "publicApiSurface": {
      "inventoryRequired": true,
      "defaultDenyRequired": true,
      "newApiOrAdminEndpointWithoutMatcherBlocksRelease": true,
      "securityMatcherComparisonRequired": true,
      "allowedPublicEndpoints": [
        "/api/health",
        "/actuator/health",
        "/actuator/health/liveness",
        "/actuator/health/readiness",
        "/actuator/prometheus",
        "/api/v1/report-uploads",
        "/api/v1/report-uploads/{uploadId}",
        "/api/v1/reports",
        "/api/v1/reports/{reportId}",
        "/api/v1/reports/{reportId}/confirm",
        "/api/v1/realtime/arrivals",
        "/api/v1/realtime/train-positions"
      ],
      "allowedPublicSecurityMatchers": [
        "/api/v1/report-uploads",
        "/api/v1/report-uploads/*",
        "/api/v1/reports",
        "/api/v1/reports/*",
        "/api/v1/reports/*/confirm",
        "/api/health",
        "/actuator/health",
        "/actuator/health/liveness",
        "/actuator/health/readiness",
        "/actuator/prometheus",
        "/api/v1/realtime/**"
      ],
      "requiredEvidence": [
        "backend-public-api-surface-inventory",
        "default-deny-public-chain-test-output",
        "security-matcher-contract-test-output"
      ]
    },
    "adminAuthTransition": {
      "basicAuthDefaultInProd": "disabled",
      "oidcMfaSsoDeferredExceptionRequired": true,
      "temporaryExceptionRequiredFields": ["owner", "untilDate", "risk", "mitigation", "followUpIssue"],
      "requiredEvidence": [
        "admin-auth-transition-decision-record",
        "admin-basic-auth-prod-disabled-test-output",
        "admin-operator-lockout-test-output",
        "break-glass-rotation-drill-record",
        "break-glass-use-immediate-rotation-record",
        "admin-credential-rotation-cadence-record"
      ]
    },
    "operatorTenantScope": {
      "temporaryScope": "operator-global",
      "releaseExceptionRequired": true,
      "requiredDecisionFields": ["owner", "untilDate", "risk", "mitigation", "followUpIssue"],
      "requiredEvidence": [
        "operator-tenant-scope-decision-record",
        "operator-global-audit-sample",
        "trusted-proxy-negative-test-output"
      ],
      "blockedWhenKo": "운영기관별 tenant 분리가 준비되지 않은 경우 operator-global 임시 scope의 owner, 만료일, risk, mitigation, follow-up issue와 audit sample이 없으면 release blocker로 처리한다."
    },
    "abuseControlReleaseException": {
      "distributedStorePreferred": true,
      "singleInstanceExceptionRequiredFields": [
        "backendReplicaCountOneEvidence",
        "scaleOutProhibitedRunbook",
        "owner",
        "untilDate",
        "postLaunchAbuseMonitoringThreshold",
        "distributedLimiterFollowUpIssue"
      ],
      "requiredEvidence": [
        "multi-instance-rate-limit-test-output-or-single-instance-exception",
        "trusted-proxy-negative-test-output",
        "abuse-store-mode-release-blocker-record"
      ]
    },
    "environmentProtection": {
      "productionRequiredReviewerRequired": true,
      "repositoryWideProductionSecretsOnlyBlocksRelease": true,
      "requiredEvidence": [
        "github-production-environment-required-reviewer-summary",
        "staging-prod-environment-separation-summary",
        "production-secret-scope-review"
      ]
    },
    "adminPageSmoke": {
      "requiredPages": [
        "dashboard",
        "stations",
        "facilities",
        "layout-editor",
        "reports",
        "quality",
        "field-verification",
        "collections",
        "batches",
        "codes",
        "incidents",
        "route-searches",
        "route-feedback",
        "push",
        "usage",
        "system",
        "audits",
        "privacy-audits"
      ],
      "requiredChecks": [
        "login-required",
        "role-denied",
        "keyboard-navigation",
        "skip-link",
        "focus-visible",
        "csrf-token",
        "error-flash",
        "environment-badge",
        "revision-master-data-version"
      ],
      "requiredEvidence": [
        "admin-operator-page-smoke-output",
        "admin-page-accessibility-smoke-output",
        "admin-role-matrix-test-output"
      ]
    },
    "auditRedaction": {
      "requiredEvidence": [
        "admin-mutating-action-audit-sample",
        "privacy-read-audit-sample",
        "report-photo-read-audit-sample",
        "break-glass-use-audit-sample"
      ],
      "forbiddenInEvidence": [
        "receipt token",
        "signed URL",
        "photo binary",
        "object storage credential",
        "raw request body"
      ]
    }
  },
  "observability": {
    "requiredResolutionKinds": [
      "dashboard-url",
      "alert-route",
      "runbook"
    ],
    "allowedFallbackKinds": [
      "external-blocker-record"
    ],
    "blockedWhenKo": "각 operations signal에 dashboard, alert route, runbook 또는 외부 blocker 기록이 없으면 운영 관측성 gate를 닫지 않는다."
  },
  "sensitiveEvidencePolicy": {
    "localOnly": true,
    "forbiddenInPullRequest": [
      "database dump",
      "photo object",
      "signed URL",
      "credential",
      "receipt token"
    ],
    "summaryRequiredKo": "민감 증거는 GitHub에 올리지 않고 PR에는 evidence 종류, 대상, 결과, local-only 경로만 적는다."
  }
}
