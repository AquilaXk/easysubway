  "evidencePolicy": {
    "localOnlyEvidenceRoot": ".codex/evidence/release/android-quality/<rc-or-run>/",
    "githubEvidencePolicy": "summary-or-public-link",
    "sensitiveEvidence": [
      "screen recordings with personal data",
      "logcat containing device identifiers",
      "network traces",
