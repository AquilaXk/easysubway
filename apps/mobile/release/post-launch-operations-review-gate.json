  "stagedRolloutPolicy": {
    "initialProductionRelease": "not-available-for-first-public-release",
    "secondAndLaterUpdates": [
      "use-staged-rollout",
      "monitor-crash-anr-support-data-provider-signals",
      "halt-rollout-on-p0-or-policy-warning",
      "resume-or-fixed-release-after-owner-approval"
