  ],
  "fixedReleaseProcedure": {
    "initialReleaseKo": "Google Play 최초 공개는 staged rollout halt가 없으므로 P0 앱 문제는 새 versionCode의 fixed release로 제출한다.",
    "requiredSteps": [
      "incident-severity-and-owner-record",
      "root-cause-summary",
      "fix-branch-and-pr-link",
      "local-emulator-regression-evidence",
      "signed-rc-artifact-evidence",
      "play-review-submission-record",
      "post-fix-monitoring-window"
    ],
    "goNoGoKo": "local emulator regression, signed RC artifact, Play submission record, fixed release monitoring owner 중 하나라도 없으면 fixed release Go가 아니다."
