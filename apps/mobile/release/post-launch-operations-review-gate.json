  ],
  "killSwitchAndRollbackOwners": [
    {
      "domain": "backend",
      "ownerKo": "백엔드 운영 담당자",
      "actionKo": "admin/report/realtime API 이상 시 backend feature flag, abuse control, CD rollback 또는 fixed release를 판단한다.",
      "evidence": ["cd-run-url", "readiness-log", "rollback-decision-record"]
    },
    {
      "domain": "datapack",
      "ownerKo": "데이터팩 운영 담당자",
      "actionKo": "데이터 오류 P0 또는 adoption 실패 시 active pack rollback, corrected pack publish, 앱 내 데이터 기준일 공지를 판단한다.",
      "evidence": ["active-pack-version", "rollback-pack-version", "datapack-adoption-summary"]
    },
    {
      "domain": "realtime",
      "ownerKo": "실시간 정보 담당자",
      "actionKo": "provider 장애, stale source, quota exhaustion 시 realtime fallback label 유지와 provider 요청 제한을 판단한다.",
