tenancy_ocid     = "ocid1.tenancy.oc1..example"
user_ocid        = "ocid1.user.oc1..example"
fingerprint      = "00:00:00:00:00:00:00:00:00:00:00:00:00:00:00:00"
private_key_path = "/absolute/path/to/oci_api_key.pem"
region           = "ap-seoul-1"

# Set when the tenancy home region differs from the resource region.
# identity_home_region = "ap-chuncheon-1"

compartment_ocid   = "ocid1.compartment.oc1..example"
availability_domain = "example:AP-SEOUL-1-AD-1"
ssh_public_key      = "ssh-ed25519 example"
ssh_ingress_cidr    = "203.0.113.10/32"

name_prefix       = "easysubway-a1"
hostname_label    = "easysubwaya1"
vcn_dns_label     = "easysubway"
subnet_dns_label  = "public"
vcn_cidr          = "10.52.0.0/16"
subnet_cidr       = "10.52.1.0/24"
http_ingress_cidr = "0.0.0.0/0"
https_ingress_cidr = "0.0.0.0/0"

instance_ocpus         = 4
instance_memory_in_gbs = 24
boot_volume_size_in_gbs = 50

create_data_volume       = true
data_volume_size_in_gbs  = 50
data_volume_vpus_per_gb  = 0
data_volume_device       = "/dev/oracleoci/oraclevdb"
data_volume_mount_path   = "/var/lib/easysubway-data"

datapack_bucket_name               = "easysubway-datapacks"
datapack_object_prefix             = ""
datapack_bucket_public_access_type = "ObjectReadWithoutList"
server_domain_name                 = "easysubway-api.aquilaxk.site"
datapack_domain_name               = "datapack.aquilaxk.site"

# Enable only after DNS/CDN for this host is configured outside this module.
# datapack_public_base_url_override = "https://datapack.aquilaxk.site"

freeform_tags = {
  Environment = "production"
  Owner       = "easysubway"
}
